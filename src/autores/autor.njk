---
layout: layouts/base.njk
pagination:
  data: authors
  size: 1
  alias: author
permalink: "/autores/{{ author.slug }}/"
eleventyComputed:
  title: "{{ author.name }}"
---

<section class="px-8 py-16 sm:px-20 bg-gradient-to-b from-terracotta-50 to-white">
  <div class="max-w-4xl mx-auto">
    <a href="/autores/" class="inline-block text-sm text-terracotta-600 hover:text-terracotta-700 mb-8">← Volver a autores</a>

    <div class="grid gap-10 md:grid-cols-[280px_1fr] items-start">
      <div class="aspect-square bg-sage-100 rounded-lg overflow-hidden border border-sage-200">
        <img src="{{ author.photo }}" alt="Retrato de {{ author.name }}" class="w-full h-full object-cover">
      </div>
      <div>
        <h1 class="text-4xl font-bold text-warm-gray-800 mb-6">{{ author.name }}</h1>
        <p class="text-warm-gray-700 leading-relaxed">{{ author.bio }}</p>
      </div>
    </div>
  </div>
</section>
