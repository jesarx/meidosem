---
layout: layouts/base.njk
title: Catálogo
permalink: /catalogo/
---

<section class="px-8 py-16 sm:px-20 bg-gradient-to-b from-terracotta-50 to-white">
  <div class="max-w-6xl mx-auto">
    <h1 class="text-4xl font-bold text-warm-gray-800 text-center mb-4">Catálogo</h1>
    <span class="block w-16 h-1 bg-terracotta-600 rounded-full mx-auto mb-12"></span>
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {% for book in books %}
        <a href="/catalogo/{{ book.slug }}/" class="group block bg-white rounded-lg overflow-hidden border border-terracotta-200 shadow-sm hover:shadow-md hover:border-terracotta-300 transition-all duration-200">
          <div class="aspect-[2/3] bg-terracotta-50 overflow-hidden">
            <img src="{{ book.cover }}" alt="Portada de {{ book.title }}" class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300">
          </div>
          <div class="p-5">
            <h3 class="text-xl font-semibold text-warm-gray-800 group-hover:text-terracotta-600 transition-colors">{{ book.title }}</h3>
            <p class="text-terracotta-700 mt-1">de {{ book.author }}</p>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>
