---
layout: layouts/base.njk
title: Inicio
---

<section class="font-josefin flex flex-col items-center justify-center min-h-[60vh] p-8 pb-20 gap-8 sm:gap-16 sm:p-20 bg-gradient-to-b">
  <div class="flex gap-4 items-center justify-center flex-col sm:flex-row text-center sm:text-left">
    <p class="text-3xl sm:text-4xl lg:text-6xl font-light uppercase text-warm-gray-800">meidosem</p>
    <img src="/images/logo.png" alt="Meidosem Ediciones" class="w-24 h-24 sm:w-32 sm:h-32 lg:w-48 lg:h-48 object-contain p-2">
    <p class="text-3xl sm:text-4xl lg:text-6xl font-light uppercase text-warm-gray-800">ediciones</p>
  </div>
</section>

<section class="px-8 py-16 sm:px-20 bg-white relative">
  <div class="max-w-3xl mx-auto text-center relative">
    <h2 class="text-3xl font-bold mb-8 text-warm-gray-800 relative inline-block">
      Sobre la editorial
      <span class="absolute -bottom-2 left-1/2 transform -translate-x-1/2 w-16 h-1 bg-terracotta-600 rounded-full"></span>
    </h2>
    <p class="text-lg leading-relaxed text-warm-gray-700 mt-6 relative">
      <span class="text-terracotta-600 text-6xl absolute -left-8 -top-4 opacity-20 font-serif">"</span>
      {{ site.description }}
      <span class="text-terracotta-600 text-6xl absolute -right-8 -bottom-4 opacity-20 font-serif">"</span>
    </p>
  </div>
  <div class="absolute top-8 left-8 w-2 h-2 bg-terracotta-600 rounded-full opacity-30"></div>
  <div class="absolute bottom-8 right-8 w-3 h-3 bg-terracotta-600 rounded-full opacity-20"></div>
</section>

<section class="px-8 py-16 sm:px-20 bg-warm-gray-50">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold mb-12 text-center text-warm-gray-800 relative">
      Libros publicados
      <span class="block w-16 h-1 bg-terracotta-600 rounded-full mx-auto mt-3"></span>
    </h2>
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {% for book in books %}
        <a href="/catalogo/{{ book.slug }}/" class="group block bg-white rounded-lg overflow-hidden border border-terracotta-200 shadow-sm hover:shadow-md hover:border-terracotta-300 transition-all duration-200">
          <div class="aspect-[2/3] bg-terracotta-50 overflow-hidden">
            <img src="{{ book.cover }}" alt="Portada de {{ book.title }}" class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300">
          </div>
          <div class="p-5">
            <h3 class="text-xl font-semibold text-warm-gray-800 group-hover:text-terracotta-600 transition-colors">{{ book.title }}</h3>
            <p class="text-terracotta-700 mt-1">de {{ book.author }}</p>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% if events and events.length %}
<section class="px-8 py-16 sm:px-20 bg-sage-50">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold mb-12 text-center text-warm-gray-800 relative">
      Próximos eventos
      <span class="block w-16 h-1 bg-terracotta-600 rounded-full mx-auto mt-3"></span>
    </h2>
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {% for event in events %}
        <button type="button"
                class="event-toggle group block w-full text-left bg-white rounded-lg overflow-hidden border border-sage-200 shadow-sm hover:shadow-md transition-all duration-200"
                data-poster="{{ event.poster }}"
                data-title="{{ event.title }}">
          <div class="aspect-[4/3] bg-sage-100 overflow-hidden">
            <img src="{{ event.thumb }}" alt="{{ event.title }}" class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300">
          </div>
          <div class="p-5">
            <h3 class="text-xl font-semibold text-warm-gray-800">{{ event.title }}</h3>
            <p class="text-sage-700 mt-1 text-sm">{{ event.date | formatDate }}</p>
            <p class="text-terracotta-600 mt-3 text-sm font-medium">Ver cartel</p>
          </div>
        </button>
      {% endfor %}
    </div>
  </div>
</section>

<div id="event-modal" class="event-modal" role="dialog" aria-modal="true" aria-label="Cartel del evento">
  <div class="event-modal__inner">
    <button type="button" class="event-modal__close" id="event-modal-close" aria-label="Cerrar">&times;</button>
    <img id="event-modal-img" class="event-modal__img" src="" alt="">
  </div>
</div>

<script>
  (function () {
    const modal = document.getElementById('event-modal');
    const modalImg = document.getElementById('event-modal-img');
    const modalClose = document.getElementById('event-modal-close');
    if (!modal || !modalImg) return;

    function openModal(src, title) {
      modalImg.src = src;
      modalImg.alt = title ? 'Cartel de ' + title : '';
      modal.classList.add('open');
      document.body.classList.add('modal-open');
    }
    function closeModal() {
      modal.classList.remove('open');
      document.body.classList.remove('modal-open');
      modalImg.src = '';
    }

    document.querySelectorAll('.event-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        openModal(btn.dataset.poster, btn.dataset.title);
      });
    });
    modalClose.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });
  })();
</script>
{% endif %}
